:root {
  --green: #003129;
  --yellow: #FCBD16;
  --bg: #f6f8f7;
  --text: #10231f;
  --muted: #6b7280;
  --white: #ffffff;
  --danger: #8b1e1e;
  --success: #0f766e;
  --radius: 24px;
  --shadow: 0 12px 30px rgba(0, 0, 0, .08);
}
* { box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  margin: 0;
  font-family: Inter, system-ui, Arial, sans-serif;
  background: var(--bg);
  color: var(--text);
}
a { text-decoration: none; color: inherit; }
.container { width: min(1200px, calc(100% - 32px)); margin: 0 auto; }
.header {
  position: sticky; top: 0; z-index: 10;
  background: var(--green); color: var(--yellow);
  box-shadow: 0 8px 20px rgba(0,0,0,.12);
}
.nav { display: flex; align-items: center; justify-content: space-between; padding: 16px 0; gap: 20px; }
.brand { display: flex; align-items: center; gap: 14px; }
.brand-badge {
  width: 52px; height: 52px; border-radius: 18px;
  background: var(--yellow); color: var(--green);
  display: grid; place-items: center; font-weight: 900;
}
.brand-title { font-size: 1.15rem; font-weight: 900; }
.nav-links { display: flex; gap: 22px; font-weight: 800; flex-wrap: wrap; }
.hero {
  background: radial-gradient(circle at top right, rgba(252,189,22,.18), transparent 25%), var(--green);
  color: white; padding: 80px 0;
}
.hero-grid, .two-col { display: grid; grid-template-columns: 1.2fr .8fr; gap: 32px; align-items: start; }
.hero h1 { color: var(--yellow); font-size: clamp(2.5rem, 5vw, 4.6rem); line-height: 1.02; margin: 0; }
.hero p { font-size: 1.08rem; line-height: 1.8; opacity: .92; }
.button {
  display: inline-flex; align-items: center; justify-content: center; gap: 8px;
  border: none; border-radius: 999px; padding: 14px 22px; cursor: pointer;
  font-weight: 900; transition: .2s transform, .2s opacity;
}
.button:hover { transform: translateY(-1px); opacity: .96; }
.button-yellow { background: var(--yellow); color: var(--green); }
.button-green { background: var(--green); color: var(--yellow); }
.button-outline { border: 1px solid rgba(255,255,255,.25); color: white; background: transparent; }
.card {
  background: var(--white); border-radius: var(--radius); box-shadow: var(--shadow);
  padding: 28px;
}
.hero-card { background: rgba(255,255,255,.07); color: white; border: 1px solid rgba(255,255,255,.12); }
.logo-circle {
  width: 220px; height: 220px; border-radius: 999px; background: var(--yellow); color: var(--green);
  display: grid; place-items: center; font-weight: 900; font-size: 1.8rem; text-align: center; margin: 0 auto;
}
.stats { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 22px; }
.stat { background: rgba(255,255,255,.1); border-radius: 20px; padding: 20px; }
.stat strong { display: block; font-size: 2rem; color: var(--yellow); }
.section { padding: 56px 0; }
.section-title small {
  display: inline-block; background: rgba(252,189,22,.15); color: #8a6500; padding: 8px 14px; border-radius: 999px; font-weight: 800;
}
.section-title h2 { color: var(--green); font-size: 2.2rem; margin: 16px 0 10px; }
.section-title p { color: var(--muted); max-width: 850px; line-height: 1.8; }
.grid-3, .grid-4 { display: grid; gap: 20px; }
.grid-3 { grid-template-columns: repeat(3, 1fr); }
.grid-4 { grid-template-columns: repeat(4, 1fr); }
label { display: block; font-weight: 800; margin-bottom: 8px; color: var(--green); }
input, textarea, select {
  width: 100%; padding: 14px 16px; border-radius: 18px; border: 1px solid #d1d5db; font: inherit; background: white;
}
textarea { min-height: 120px; resize: vertical; }
.form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.notice { border-radius: 18px; padding: 14px 16px; margin-bottom: 16px; font-weight: 700; }
.notice-error { background: #fef2f2; color: #991b1b; }
.notice-success { background: #ecfdf5; color: #065f46; }
.footer { background: var(--green); color: #d1d5db; padding: 28px 0; margin-top: 40px; }
.admin-layout { display: grid; grid-template-columns: 380px 1fr; gap: 24px; }
.table-wrap { overflow: auto; border-radius: 20px; border: 1px solid #e5e7eb; }
table { width: 100%; border-collapse: collapse; background: white; }
thead { background: var(--green); color: var(--yellow); }
th, td { padding: 14px; text-align: left; vertical-align: top; border-bottom: 1px solid #e5e7eb; }
.inline-form { display: inline; }
.actions { display: flex; gap: 8px; flex-wrap: wrap; }
.small { font-size: .9rem; color: var(--muted); }
.top-actions { display: flex; gap: 10px; flex-wrap: wrap; }
.sport-row { border: 1px solid #e5e7eb; border-radius: 20px; padding: 16px; margin-bottom: 12px; }
.login-box { width: min(520px, calc(100% - 32px)); margin: 80px auto; }
@media (max-width: 980px) {
  .hero-grid, .two-col, .admin-layout, .grid-3, .grid-4, .form-grid { grid-template-columns: 1fr; }
  .nav { align-items: flex-start; flex-direction: column; }
  .nav-links { gap: 12px; }
}

.form-card { max-width: 980px; margin: 0 auto; }
.field-grid.two { display:grid; grid-template-columns: repeat(auto-fit,minmax(240px,1fr)); gap:16px; }
.nested-card { margin-top: 18px; }
.radio-group { display:flex; gap:16px; flex-wrap:wrap; align-items:center; }
.checkbox { display:block; margin:10px 0; }
.checkbox.inline { display:flex; align-items:center; gap:8px; }
.spaced-top { margin-top: 12px; }
.table-wrap { overflow:auto; }
.table-wrap table { width:100%; border-collapse: collapse; }
.table-wrap th, .table-wrap td { border:1px solid #d8dde2; padding:10px; vertical-align:top; }
.admin-grid { display:grid; grid-template-columns: 1fr 1fr; gap:20px; }
.sport-row { display:grid; grid-template-columns: 1.5fr .9fr .7fr auto auto; gap:10px; align-items:center; margin-bottom:10px; }
@media (max-width: 900px){ .admin-grid { grid-template-columns: 1fr; } .sport-row { grid-template-columns:1fr; } }
