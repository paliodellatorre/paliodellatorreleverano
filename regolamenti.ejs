<%- include('partials/header') %>

<section class="hero">
  <div class="container hero-grid">
    <div>
      <h1>Il Palio della Torre</h1>
      <p class="small" style="color:#FCBD16;font-weight:800;letter-spacing:.4px;">Torneo dei Rioni · Iscrizioni 2026</p>
      <p>
        Un evento che unisce sport, appartenenza e tradizione. Il Palio della Torre rappresenta la sfida tra rioni,
        la passione della comunità e lo spirito di squadra.
      </p>
      <div class="top-actions" style="margin-top:22px;">
        <a href="/iscrizioni?ok=1" class="button button-yellow">Vai alle iscrizioni</a>
        <a href="/novita?ok=1" class="button button-outline">Guarda le novità</a>
      </div>
    </div>

    <div class="card hero-card">
      <div class="logo-circle" style="padding:0; overflow:hidden; background:transparent;">
        <img src="/logo-pdt.png" alt="Logo Palio" style="width:100%; height:100%; object-fit:cover; border-radius:999px;">
      </div>
      <div class="stats">
        <div class="stat"><strong><%= sports.length %></strong><span>Sport aperti</span></div>
        <div class="stat"><strong><%= settings.registrations_open === 'true' ? 'ON' : 'OFF' %></strong><span>Iscrizioni</span></div>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-title">
      <small>Storia del torneo</small>
      <h2>Storia del torneo dei rioni</h2>
      <p style="font-weight:900;font-size:22px;color:var(--green);letter-spacing:1px;">#DIVIDEREPERUNIRE</p>
    </div>
    <div class="grid-3">
      <div class="card">Nato per valorizzare il senso di appartenenza ai rioni e creare un momento di festa condivisa.</div>
      <div class="card">Negli anni il Palio è diventato un appuntamento fisso, coinvolgendo atleti, famiglie, sponsor e volontari.</div>
      <div class="card">Oggi è una manifestazione simbolo di aggregazione, competizione sana e orgoglio locale.</div>
    </div>
  </div>
</section>

<section id="novita-home" class="section" style="padding-top:0;">
  <div class="container">
    <div class="section-title">
      <small>Aggiornamenti</small>
      <h2>NOVITÀ</h2>
      <p class="small">Le ultime locandine e comunicazioni ufficiali del Palio.</p>
    </div>

    <% if (news && news.length) { %>
      <div style="display:grid; grid-template-columns:1fr; gap:18px;">
        <% news.forEach(function(item) { %>
          <div class="card" style="text-align:center; padding:20px;">
            <% if (item.titolo) { %>
              <div style="font-weight:900;color:var(--green);margin-bottom:12px;"><%= item.titolo %></div>
            <% } %>
            <img
              src="<%= item.image_url %>"
              alt="Locandina novità"
              loading="lazy"
              style="width:100%; max-height:760px; object-fit:contain; display:block; border-radius:12px;"
            />
          </div>
        <% }) %>
      </div>
      <div style="margin-top:18px; text-align:center;">
        <a class="button button-green" href="/novita?ok=1">Vedi tutte le novità</a>
      </div>
    <% } else { %>
      <div class="card">Nessuna novità disponibile al momento.</div>
    <% } %>
  </div>
</section>

<%- include('partials/promo-video') %>
<%- include('partials/footer') %>
