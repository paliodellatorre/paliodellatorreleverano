<%- include('partials/header') %>

<section class="hero">
  <div class="container hero-grid">
    <div>
      <h1>Il Palio della Torre</h1>
      <p class="small" style="color:#FCBD16;font-weight:800;letter-spacing:.4px;">Torneo dei Rioni · Iscrizioni 2026</p>
      <p>
        Un evento che unisce sport, appartenenza e tradizione.
        Il Palio della Torre rappresenta la sfida tra rioni,
        la passione della comunità e lo spirito di squadra.
      </p>

      <div class="top-actions" style="margin-top:22px;">
        <a href="#iscrizioni" class="button button-yellow">Vai alle iscrizioni</a>
        <a href="#regolamenti" class="button button-outline">Scopri i regolamenti</a>
      </div>
    </div>

    <div class="card hero-card">
      <div class="logo-circle" style="padding:0; overflow:hidden; background:transparent;">
        <img
          src="/logo-pdt.png"
          alt="Logo Palio"
          style="width:100%; height:100%; object-fit:cover; border-radius:999px;"
        />
      </div>

      <div class="stats">
        <div class="stat">
          <strong><%= sports.length %></strong>
          <span>Sport aperti</span>
        </div>
        <div class="stat">
          <strong><%= settings.registrations_open === 'true' ? 'ON' : 'OFF' %></strong>
          <span>Iscrizioni</span>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-title">
      <small>Storia del torneo</small>
      <h2>Storia del torneo dei rioni</h2>
      <p style="font-weight:900; font-size:22px; color:var(--green); letter-spacing:1px;">
  #DIVIDEREPERUNIRE
</p>
    </div>

    <div class="grid-3">
      <div class="card">
        Nato per valorizzare il senso di appartenenza ai rioni e creare un momento di festa condivisa.
      </div>
      <div class="card">
        Negli anni il Palio è diventato un appuntamento fisso, coinvolgendo atleti, famiglie, sponsor e volontari.
      </div>
      <div class="card">
        Oggi è una manifestazione simbolo di aggregazione, competizione sana e orgoglio locale.
      </div>
    </div>
  </div>
</section>

<section id="iscrizioni" class="section">
  <div class="container two-col">
    <div class="card">
      <h2>Iscrizioni sport</h2>
      <p style="margin-top:0;">
        Compila il modulo dal tuo smartphone. Per gli sport di coppia devi inserire anche il compagno dello stesso rione.
      </p>

      <% if (errors && errors.length) { %>
        <div class="notice notice-error">
          <% errors.forEach(function(error) { %>
            <div><%= error %></div>
          <% }) %>
        </div>
      <% } %>

      <form method="POST" action="/iscrizioni" id="palioForm">
        <div class="form-grid">
          <div>
            <label>Sport *</label>
            <select name="sport_id" id="sport_id" required>
              <option value="">Seleziona uno sport</option>
              <% sports.forEach(function(sport) { 
                   const lowerName = String(sport.name || '').toLowerCase();
                   const isPair = lowerName.includes('coppia') || ['padel','burraco','scopa','biliardino'].some(k => lowerName.includes(k));
              %>
                <option
                  value="<%= sport.id %>"
                  data-name="<%= sport.name %>"
                  data-price="<%= Number(sport.price).toFixed(2) %>"
                  data-pair="<%= isPair ? 'true' : 'false' %>"
                  <%= String(formData.sport_id || '') === String(sport.id) ? 'selected' : '' %>
                >
                  <%= sport.name %> — €<%= Number(sport.price).toFixed(2) %><%= isPair ? ' a coppia' : '' %>
                </option>
              <% }) %>
            </select>
          </div>

          <div>
            <label>Email *</label>
            <input type="email" name="email" value="<%= formData.email || '' %>" required />
            <div class="small" style="margin-top:8px;">La email verrà registrata insieme all'iscrizione.</div>
          </div>

          <div>
            <label>Rione *</label>
            <select name="rione" required>
              <option value="">Scegli il tuo rione</option>
              <% rioni.forEach(function(rione) { %>
                <option value="<%= rione %>" <%= formData.rione === rione ? 'selected' : '' %>>
                  <%= rione %>
                </option>
              <% }) %>
            </select>

            <div class="small" style="margin-top:8px;">
              Consulta la mappa dei rioni
              <a
                href="https://www.google.com/maps/@40.2878732,17.9905045,15z/data=!3m1!4b1!4m2!6m1!1s1AiNo30X3Qloy24nwtxUo06kHozB_yC4?authuser=1&entry=ttu&g_ep=EgoyMDI1MDUwNi4wIKXMDSoASAFQAw%3D%3D"
                target="_blank"
                rel="noopener noreferrer"
                style="text-decoration: underline; font-weight: 800;"
              >
                qui
              </a>
            </div>
          </div>

          <div>
            <label>Conferma quota *</label>
            <div class="card" style="padding:16px; border-radius:18px; box-shadow:none; border:1px solid #e5e7eb;">
              <div style="line-height:1.7;">
                Confermo di aver compreso che l'iscrizione ha un costo di
                <strong id="quotaLabel">seleziona uno sport</strong>
                da consegnare agli organizzatori prima dell'inizio del torneo.
                La maglia del proprio rione può essere acquistata a parte a € 5.
              </div>

              <div class="radio-row" style="margin-top:12px;">
                <label class="radio-inline">
                  <input type="radio" name="fee_confirmation" value="yes" required>
                  <span>Sì</span>
                </label>

                <label class="radio-inline">
                  <input type="radio" name="fee_confirmation" value="no">
                  <span>No</span>
                </label>
              </div>
            </div>
          </div>
        </div>

        <div class="card" style="margin-top:20px;">
          <h3 style="margin-top:0;color:var(--green);">1° giocatore</h3>

          <div class="form-grid">
            <div>
              <label>Nome e Cognome 1° giocatore *</label>
              <input name="player1_full_name" required />
            </div>

            <div>
              <label>Codice fiscale 1° giocatore *</label>
              <input name="player1_tax_code" required />
            </div>

            <div>
              <label>Numero di telefono 1° giocatore *</label>
              <input name="player1_phone" required />
            </div>

            <div>
              <label>Criterio di appartenenza al Rione *</label>
              <select name="player1_rione_criteria" required>
                <option value="">Seleziona</option>
                <option value="Residenza">Residenza</option>
                <option value="Domicilio">Domicilio</option>
                <option value="Legame familiare">Legame familiare</option>
                <option value="Altro criterio approvato">Altro criterio approvato</option>
              </select>
            </div>
          </div>

          <div style="margin-top:16px;">
            <label>Indirizzo di appartenenza al Rione 1° giocatore *</label>
            <input name="player1_rione_address" required />
          </div>

          <div class="radio-row" style="margin-top:16px;">
            <span style="font-weight:800;color:var(--green);">Vuoi acquistare la maglia del rione per il 1° giocatore? (+ € 5)</span>

            <label class="radio-inline">
              <input type="radio" name="player1_shirt" value="yes" required>
              <span>Sì</span>
            </label>

            <label class="radio-inline">
              <input type="radio" name="player1_shirt" value="no">
              <span>No</span>
            </label>
          </div>

          <div id="player1_size_wrap" style="margin-top:16px; display:none;">
            <label>Taglia maglia 1° giocatore *</label>
            <select name="player1_shirt_size" id="player1_shirt_size">
              <option value="">Seleziona taglia</option>
              <option value="XS">XS</option>
              <option value="S">S</option>
              <option value="M">M</option>
              <option value="L">L</option>
              <option value="XL">XL</option>
              <option value="XXL">XXL</option>
            </select>
          </div>
        </div>

        <div class="card" id="secondPlayerCard" style="margin-top:20px; display:none;">
          <h3 style="margin-top:0;color:var(--green);">2° giocatore</h3>

          <div class="form-grid">
            <div>
              <label>Nome e Cognome 2° giocatore *</label>
              <input name="player2_full_name" id="player2_full_name" />
            </div>

            <div>
              <label>Codice fiscale 2° giocatore *</label>
              <input name="player2_tax_code" id="player2_tax_code" />
            </div>

            <div>
              <label>Numero di telefono 2° giocatore *</label>
              <input name="player2_phone" id="player2_phone" />
            </div>

            <div>
              <label>Criterio di appartenenza al Rione *</label>
              <select name="player2_rione_criteria" id="player2_rione_criteria">
                <option value="">Seleziona</option>
                <option value="Residenza">Residenza</option>
                <option value="Domicilio">Domicilio</option>
                <option value="Legame familiare">Legame familiare</option>
                <option value="Altro criterio approvato">Altro criterio approvato</option>
              </select>
            </div>
          </div>

          <div style="margin-top:16px;">
            <label>Indirizzo di appartenenza al Rione 2° giocatore *</label>
            <input name="player2_rione_address" id="player2_rione_address" />
          </div>

          <div class="radio-row" style="margin-top:16px;">
            <span style="font-weight:800;color:var(--green);">Vuoi acquistare la maglia del rione per il 2° giocatore? (+ € 5)</span>

            <label class="radio-inline">
              <input type="radio" name="player2_shirt" value="yes">
              <span>Sì</span>
            </label>

            <label class="radio-inline">
              <input type="radio" name="player2_shirt" value="no">
              <span>No</span>
            </label>
          </div>

          <div id="player2_size_wrap" style="margin-top:16px; display:none;">
            <label>Taglia maglia 2° giocatore *</label>
            <select name="player2_shirt_size" id="player2_shirt_size">
              <option value="">Seleziona taglia</option>
              <option value="XS">XS</option>
              <option value="S">S</option>
              <option value="M">M</option>
              <option value="L">L</option>
              <option value="XL">XL</option>
              <option value="XXL">XXL</option>
            </select>
          </div>
        </div>

        <div class="card" style="margin-top:20px;">
          <h3 style="margin-top:0;color:var(--green);">Conferme obbligatorie</h3>

          <label class="checkbox">
            <input type="checkbox" name="terms_rione_check" value="yes" required />
            Confermo di aver compreso che l'appartenenza al Rione verrà verificata pena l'esclusione da tutte le attività del Torneo dei Rioni.
          </label>

          <label class="checkbox">
            <input type="checkbox" name="terms_organizer_confirmation" value="yes" required />
            Confermo di aver compreso che l'iscrizione dovrà essere confermata dagli organizzatori.
          </label>

          <label class="checkbox">
            <input type="checkbox" name="terms_privacy" value="yes" required />
            Autorizzo il trattamento dei dati personali nel rispetto del Regolamento Europeo 2016/679 e normativa vigente.
          </label>

          <label class="checkbox">
            <input type="checkbox" name="terms_images" value="yes" required />
            Autorizzo la pubblicazione e/o diffusione gratuita delle immagini sui canali social del Palio della Torre e associazioni collegate.
          </label>

          <label class="checkbox">
            <input type="checkbox" name="terms_liability" value="yes" required />
            I partecipanti si assumono ogni responsabilità per l'attività sportiva e sollevano gli organizzatori da responsabilità civili e penali.
          </label>
        </div>

        <div style="margin-top:16px;">
          <label>Note</label>
          <textarea name="notes"><%= formData.notes || '' %></textarea>
        </div>

        <div style="margin-top:18px;">
          <button class="button button-yellow" type="submit">Invia iscrizione</button>
        </div>
      </form>
    </div>

    <div class="card">
      <h3 style="margin-top:0;color:var(--green);">Come funziona</h3>
      <p style="line-height:1.9; margin-bottom:0;">
        <strong>1.</strong> Scegli il tuo sport.<br>
        <strong>2.</strong> Inserisci i tuoi dati.<br>
        <strong>3.</strong> Richiedi la maglietta del tuo rione.<br>
        <strong>4.</strong> E il gioco è fatto.
      </p>
    </div>
  </div>
</section>

<section id="regolamenti" class="section">
  <div class="container">
    <div class="section-title">
      <small>Regolamenti</small>
      <h2>Regolamenti</h2>
      <p>
        Qui compariranno automaticamente i regolamenti caricati dal pannello admin.
      </p>
    </div>

    <div class="grid-4">
      <% if (regulations && regulations.length) { %>
        <% regulations.forEach(function(reg) { %>
          <a href="<%= reg.file_url %>" target="_blank" class="card">
            <strong><%= reg.titolo %></strong>
          </a>
        <% }) %>
      <% } else { %>
        <div class="card">Regolamento generale</div>
        <div class="card">Regolamento Padel</div>
        <div class="card">Regolamento Calcio</div>
        <div class="card">Privacy e trattamento dati</div>
      <% } %>
    </div>
  </div>
</section>

<section id="chi-siamo" class="section">
  <div class="container">
    <div class="section-title">
      <small>Organizzazione</small>
      <h2>Chi siamo</h2>
      <p>
        Una sezione dedicata all’organizzazione, ai volontari e al significato del Palio della Torre per il territorio.
      </p>
    </div>

    <div class="card">
     Il Palio della Torre di Leverano è una manifestazione sportiva e comunitaria che coinvolge i rioni del paese in sfide sportive e momenti di aggregazione, promuovendo lo spirito di squadra, il fair play e il senso di appartenenza al territorio.
Nato nel 2021, il Palio è cresciuto anno dopo anno diventando un appuntamento atteso da tutta la comunità, capace di unire giovani, famiglie e associazioni in un clima di festa e sana competizione.
La manifestazione rappresenta un'occasione unica per valorizzare lo sport, rafforzare i legami tra i cittadini e celebrare le tradizioni locali, trasformando ogni edizione in un momento di condivisione e partecipazione collettiva.
Il Palio della Torre si svolge con il patrocinio del Comune di Leverano, a testimonianza dell'importanza dell'evento per la comunità e per la promozione dei valori sportivi e sociali.
    </div>
  </div>
</section>

<section id="contatti" class="section">
  <div class="container">
    <div class="section-title">
      <small>Contatti</small>
      <h2>Contatti</h2>
      <p>
        Seguici sui canali ufficiali del Palio della Torre.
      </p>
    </div>

    <div class="grid-3">
      <div class="card">
        <strong>Facebook</strong>
        <div style="margin-top:10px;">
          <%= settings.contact_facebook || 'Il Palio della Torre - Torneo dei Rioni Leverano' %>
        </div>
      </div>

      <div class="card">
        <strong>Instagram</strong>
        <div style="margin-top:10px;">
          <%= settings.contact_instagram || 'ilpaliodellatorreleverano' %>
        </div>
      </div>

      <div class="card">
        <strong>Email</strong>
        <div style="margin-top:10px;">
          <%= settings.contact_email || '---' %>
        </div>
      </div>
    </div>
  </div>
</section>

<section id="sponsor" class="section">
  <div class="container">
    <div class="section-title">
      <small>Partner</small>
      <h2>Sponsor</h2>
      <p>
        Loghi caricati direttamente dal pannello admin.
      </p>
    </div>

    <% if (sponsors && sponsors.length) { %>
      <div style="display:grid; grid-template-columns:1fr; gap:20px;">
        <% sponsors.forEach(function(sponsor) { %>
          <div class="card" style="text-align:center; padding:28px;">
            <img
              src="<%= sponsor.logo_url %>"
              alt="Sponsor"
              style="max-width:100%; max-height:140px; object-fit:contain;"
            />
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div style="display:grid; grid-template-columns:1fr; gap:20px;">
        <div class="card">Sponsor 1</div>
        <div class="card">Sponsor 2</div>
        <div class="card">Sponsor 3</div>
        <div class="card">Sponsor 4</div>
      </div>
    <% } %>
  </div>
</section>

<script>
  (function () {
    const sportSelect = document.getElementById('sport_id');
    const quotaLabel = document.getElementById('quotaLabel');
    const secondPlayerCard = document.getElementById('secondPlayerCard');

    const secondPlayerFields = [
      document.getElementById('player2_full_name'),
      document.getElementById('player2_tax_code'),
      document.getElementById('player2_phone'),
      document.getElementById('player2_rione_criteria'),
      document.getElementById('player2_rione_address')
    ];

    const player1ShirtYes = document.querySelector('input[name="player1_shirt"][value="yes"]');
    const player1ShirtNo = document.querySelector('input[name="player1_shirt"][value="no"]');
    const player1SizeWrap = document.getElementById('player1_size_wrap');
    const player1Size = document.getElementById('player1_shirt_size');

    const player2ShirtYes = document.querySelector('input[name="player2_shirt"][value="yes"]');
    const player2ShirtNo = document.querySelector('input[name="player2_shirt"][value="no"]');
    const player2SizeWrap = document.getElementById('player2_size_wrap');
    const player2Size = document.getElementById('player2_shirt_size');

    function updateSportUI() {
      const option = sportSelect.options[sportSelect.selectedIndex];

      if (!option || !option.value) {
        quotaLabel.textContent = 'seleziona uno sport';
        secondPlayerCard.style.display = 'none';
        secondPlayerFields.forEach(el => el && el.removeAttribute('required'));
        return;
      }

      const price = option.getAttribute('data-price') || '0.00';
      const isPair = option.getAttribute('data-pair') === 'true';

      quotaLabel.textContent = '€' + price + (isPair ? ' a coppia' : '');

      if (isPair) {
        secondPlayerCard.style.display = 'block';
        secondPlayerFields.forEach(el => el && el.setAttribute('required', 'required'));
      } else {
        secondPlayerCard.style.display = 'none';
        secondPlayerFields.forEach(el => el && el.removeAttribute('required'));
        if (player2SizeWrap) player2SizeWrap.style.display = 'none';
        if (player2Size) player2Size.removeAttribute('required');
      }
    }

    function updatePlayer1ShirtUI() {
      if (player1ShirtYes && player1ShirtYes.checked) {
        player1SizeWrap.style.display = 'block';
        player1Size.setAttribute('required', 'required');
      } else {
        player1SizeWrap.style.display = 'none';
        player1Size.removeAttribute('required');
        player1Size.value = '';
      }
    }

    function updatePlayer2ShirtUI() {
      if (player2ShirtYes && player2ShirtYes.checked && secondPlayerCard.style.display !== 'none') {
        player2SizeWrap.style.display = 'block';
        player2Size.setAttribute('required', 'required');
      } else {
        player2SizeWrap.style.display = 'none';
        player2Size.removeAttribute('required');
        player2Size.value = '';
      }
    }

    if (sportSelect) {
      sportSelect.addEventListener('change', updateSportUI);
      updateSportUI();
    }

    if (player1ShirtYes) player1ShirtYes.addEventListener('change', updatePlayer1ShirtUI);
    if (player1ShirtNo) player1ShirtNo.addEventListener('change', updatePlayer1ShirtUI);

    if (player2ShirtYes) player2ShirtYes.addEventListener('change', updatePlayer2ShirtUI);
    if (player2ShirtNo) player2ShirtNo.addEventListener('change', updatePlayer2ShirtUI);

    updatePlayer1ShirtUI();
    updatePlayer2ShirtUI();
  })();
</script>

<%- include('partials/footer') %>
