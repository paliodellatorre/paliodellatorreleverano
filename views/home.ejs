<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Palio della Torre Leverano - Iscrizioni</title>
  <style>
    :root {
      --green: #003129;
      --yellow: #FCBD16;
      --bg: #f4f6f5;
      --text: #1f2937;
      --muted: #6b7280;
      --border: #d1d5db;
      --white: #ffffff;
      --danger: #b91c1c;
      --success: #166534;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      background: var(--bg);
      color: var(--text);
    }

    .page {
      width: 100%;
      padding: 30px 16px 60px;
    }

    .card {
      max-width: 900px;
      margin: 0 auto;
      background: var(--white);
      border-radius: 18px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.08);
      overflow: hidden;
      border: 1px solid #e5e7eb;
    }

    .header {
      background: var(--green);
      color: var(--yellow);
      padding: 28px 24px;
      text-align: center;
    }

    .header h1 {
      margin: 0;
      font-size: 32px;
      line-height: 1.15;
    }

    .header p {
      margin: 10px auto 0;
      max-width: 760px;
      font-size: 15px;
      color: #f8fafc;
      opacity: 0.95;
    }

    .content {
      padding: 28px 24px 34px;
    }

    .alert {
      padding: 14px 16px;
      border-radius: 12px;
      margin-bottom: 18px;
      font-size: 14px;
    }

    .alert-error {
      background: #fef2f2;
      color: var(--danger);
      border: 1px solid #fecaca;
    }

    .alert-success {
      background: #f0fdf4;
      color: var(--success);
      border: 1px solid #bbf7d0;
    }

    .section {
      margin-bottom: 28px;
      padding-bottom: 20px;
      border-bottom: 1px solid #e5e7eb;
    }

    .section:last-of-type {
      border-bottom: none;
      margin-bottom: 18px;
    }

    .section-title {
      margin: 0 0 16px;
      font-size: 22px;
      color: var(--green);
    }

    .grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }

    .grid-1 {
      display: grid;
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .field {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .field label {
      font-weight: 700;
      font-size: 14px;
      color: var(--green);
    }

    .field small {
      color: var(--muted);
      font-size: 13px;
      line-height: 1.4;
    }

    input[type="text"],
    input[type="email"],
    select,
    textarea {
      width: 100%;
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 12px 14px;
      font-size: 15px;
      outline: none;
      background: #fff;
    }

    input[type="text"]:focus,
    input[type="email"]:focus,
    select:focus,
    textarea:focus {
      border-color: var(--green);
      box-shadow: 0 0 0 3px rgba(0, 49, 41, 0.08);
    }

    .link-inline {
      color: var(--green);
      font-weight: 700;
      text-decoration: underline;
    }

    .quota-box {
      background: #fffbea;
      border: 1px solid #fde68a;
      color: #78350f;
      border-radius: 12px;
      padding: 14px 16px;
      font-size: 15px;
      line-height: 1.5;
    }

    .quota-strong {
      font-weight: 800;
      color: var(--green);
    }

    .radio-group,
    .check-group {
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin-top: 12px;
    }

    .inline-option {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      font-size: 14px;
      line-height: 1.45;
    }

    .inline-option input {
      margin-top: 3px;
      transform: scale(1.05);
    }

    .pair-box {
      background: #f8fafc;
      border: 1px solid #e5e7eb;
      border-radius: 14px;
      padding: 18px;
      margin-top: 12px;
    }

    .submit-btn {
      width: 100%;
      border: none;
      border-radius: 12px;
      background: var(--green);
      color: var(--yellow);
      padding: 15px 18px;
      font-size: 17px;
      font-weight: 800;
      cursor: pointer;
      transition: 0.2s ease;
    }

    .submit-btn:hover {
      opacity: 0.95;
      transform: translateY(-1px);
    }

    .muted-note {
      font-size: 13px;
      color: var(--muted);
      margin-top: 6px;
    }

    @media (max-width: 768px) {
      .header h1 {
        font-size: 26px;
      }

      .content {
        padding: 20px 16px 28px;
      }

      .grid {
        grid-template-columns: 1fr;
      }

      .section-title {
        font-size: 20px;
      }
    }
  </style>
</head>
<body>
  <div class="page">
    <div class="card">
      <div class="header">
        <h1>Palio della Torre Leverano<br>ISCRIZIONI SPORT</h1>
        <p>
          Compila il modulo dal tuo smartphone. Per gli sport di coppia devi inserire
          anche il compagno dello stesso rione.
        </p>
      </div>

      <div class="content">
        <% if (typeof errors !== 'undefined' && errors && errors.length) { %>
          <div class="alert alert-error">
            <strong>Controlla questi campi:</strong>
            <ul style="margin:8px 0 0 18px; padding:0;">
              <% errors.forEach(function(error) { %>
                <li><%= error %></li>
              <% }) %>
            </ul>
          </div>
        <% } %>

        <% if (flash && flash.type === 'success') { %>
          <div class="alert alert-success">
            <%= flash.message %>
          </div>
        <% } %>

        <form method="POST" action="/iscrizioni">
          <div class="section">
            <h2 class="section-title">Dati iscrizione</h2>

            <div class="grid">
              <div class="field">
                <label for="sport_id">Sport *</label>
                <select name="sport_id" id="sport_id" required>
                  <option value="">Seleziona uno sport</option>
                  <% sports.forEach(function(sport) { %>
                    <option
                      value="<%= sport.id %>"
                      data-price="<%= sport.price %>"
                      data-type="<%= sport.team_type %>"
                      <%= String(formData?.sport_id || '') === String(sport.id) ? 'selected' : '' %>
                    >
                      <%= sport.name %>
                    </option>
                  <% }) %>
                </select>
              </div>

              <div class="field">
                <label for="email">Email *</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  placeholder="nome@email.it"
                  value="<%= formData?.email || '' %>"
                  required
                />
                <small>La email verrà registrata insieme all'iscrizione.</small>
              </div>
            </div>

            <div class="grid" style="margin-top:16px;">
              <div class="field">
                <label for="rione">Rione *</label>
                <select name="rione" id="rione" required>
                  <option value="">Scegli il tuo rione</option>
                  <% rioni.forEach(function(rione) { %>
                    <option value="<%= rione %>" <%= formData?.rione === rione ? 'selected' : '' %>>
                      <%= rione %>
                    </option>
                  <% }) %>
                </select>
                <small>
                  Consulta la mappa dei rioni
                  <a
                    class="link-inline"
                    href="https://www.google.com/maps/@40.2878732,17.9905045,15z/data=!3m1!4b1!4m2!6m1!1s1AiNo30X3Qloy24nwtxUo06kHozB_yC4?authuser=1&entry=ttu&g_ep=EgoyMDI1MDUwNi4wIKXMDSoASAFQAw%3D%3D"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    qui
                  </a>
                </small>
              </div>
            </div>
          </div>

          <div class="section">
            <h2 class="section-title">Conferma quota</h2>

            <div class="quota-box">
              Confermo di aver compreso che l'iscrizione ha un costo di
              <span class="quota-strong" id="quotaText">--</span>
              da consegnare agli organizzatori prima dell'inizio del torneo.
              La maglia del proprio rione può essere acquistata a parte a € 5.
            </div>

            <div class="radio-group">
              <label class="inline-option">
                <input
                  type="radio"
                  name="fee_confirmation"
                  value="yes"
                  <%= formData?.fee_confirmation === 'yes' ? 'checked' : '' %>
                  required
                />
                <span>Sì</span>
              </label>

              <label class="inline-option">
                <input
                  type="radio"
                  name="fee_confirmation"
                  value="no"
                  <%= formData?.fee_confirmation === 'no' ? 'checked' : '' %>
                />
                <span>No</span>
              </label>
            </div>
          </div>

          <div class="section">
            <h2 class="section-title">1° giocatore</h2>

            <div class="grid">
              <div class="field">
                <label for="player1_full_name">Nome e Cognome 1° giocatore *</label>
                <input
                  type="text"
                  id="player1_full_name"
                  name="player1_full_name"
                  value="<%= formData?.player1_full_name || '' %>"
                  required
                />
              </div>

              <div class="field">
                <label for="player1_tax_code">Codice fiscale 1° giocatore *</label>
                <input
                  type="text"
                  id="player1_tax_code"
                  name="player1_tax_code"
                  value="<%= formData?.player1_tax_code || '' %>"
                  required
                />
              </div>
            </div>

            <div class="grid" style="margin-top:16px;">
              <div class="field">
                <label for="player1_phone">Numero di telefono 1° giocatore *</label>
                <input
                  type="text"
                  id="player1_phone"
                  name="player1_phone"
                  value="<%= formData?.player1_phone || '' %>"
                  required
                />
              </div>

              <div class="field">
                <label for="player1_rione_criteria">Criterio di appartenenza al Rione *</label>
                <select id="player1_rione_criteria" name="player1_rione_criteria" required>
                  <option value="">Seleziona</option>
                  <% rioneCriteria.forEach(function(c) { %>
                    <option value="<%= c %>" <%= formData?.player1_rione_criteria === c ? 'selected' : '' %>>
                      <%= c %>
                    </option>
                  <% }) %>
                </select>
              </div>
            </div>

            <div class="grid" style="margin-top:16px;">
              <div class="field">
                <label for="player1_rione_address">Indirizzo di appartenenza al Rione 1° giocatore *</label>
                <input
                  type="text"
                  id="player1_rione_address"
                  name="player1_rione_address"
                  value="<%= formData?.player1_rione_address || '' %>"
                  required
                />
              </div>
            </div>

            <div class="check-group">
              <label class="inline-option">
                <input
                  type="checkbox"
                  name="player1_shirt"
                  value="yes"
                  <%= formData?.player1_shirt === 'yes' ? 'checked' : '' %>
                />
                <span>Vuoi acquistare la maglia del rione per il 1° giocatore? (+ € 5)</span>
              </label>
            </div>
          </div>

          <div class="section pair-box" id="secondPlayerSection" style="display:none;">
            <h2 class="section-title">2° giocatore</h2>

            <div class="grid">
              <div class="field">
                <label for="player2_full_name">Nome e Cognome 2° giocatore *</label>
                <input
                  type="text"
                  id="player2_full_name"
                  name="player2_full_name"
                  value="<%= formData?.player2_full_name || '' %>"
                />
              </div>

              <div class="field">
                <label for="player2_tax_code">Codice fiscale 2° giocatore *</label>
                <input
                  type="text"
                  id="player2_tax_code"
                  name="player2_tax_code"
                  value="<%= formData?.player2_tax_code || '' %>"
                />
              </div>
            </div>

            <div class="grid" style="margin-top:16px;">
              <div class="field">
                <label for="player2_phone">Numero di telefono 2° giocatore *</label>
                <input
                  type="text"
                  id="player2_phone"
                  name="player2_phone"
                  value="<%= formData?.player2_phone || '' %>"
                />
              </div>

              <div class="field">
                <label for="player2_rione_criteria">Criterio di appartenenza al Rione *</label>
                <select id="player2_rione_criteria" name="player2_rione_criteria">
                  <option value="">Seleziona</option>
                  <% rioneCriteria.forEach(function(c) { %>
                    <option value="<%= c %>" <%= formData?.player2_rione_criteria === c ? 'selected' : '' %>>
                      <%= c %>
                    </option>
                  <% }) %>
                </select>
              </div>
            </div>

            <div class="grid" style="margin-top:16px;">
              <div class="field">
                <label for="player2_rione_address">Indirizzo di appartenenza al Rione 2° giocatore *</label>
                <input
                  type="text"
                  id="player2_rione_address"
                  name="player2_rione_address"
                  value="<%= formData?.player2_rione_address || '' %>"
                />
              </div>
            </div>

            <div class="check-group">
              <label class="inline-option">
                <input
                  type="checkbox"
                  name="player2_shirt"
                  value="yes"
                  <%= formData?.player2_shirt === 'yes' ? 'checked' : '' %>
                />
                <span>Vuoi acquistare la maglia del rione per il 2° giocatore? (+ € 5)</span>
              </label>
            </div>
          </div>

          <div class="section">
            <h2 class="section-title">Conferme obbligatorie</h2>

            <div class="check-group">
              <label class="inline-option">
                <input
                  type="checkbox"
                  name="terms_rione_check"
                  value="yes"
                  <%= formData?.terms_rione_check === 'yes' ? 'checked' : '' %>
                  required
                />
                <span>
                  Confermo di aver compreso che l'appartenenza al Rione verrà verificata
                  pena l'esclusione da tutte le attività del Torneo dei Rioni.
                </span>
              </label>

              <label class="inline-option">
                <input
                  type="checkbox"
                  name="terms_organizer_confirmation"
                  value="yes"
                  <%= formData?.terms_organizer_confirmation === 'yes' ? 'checked' : '' %>
                  required
                />
                <span>
                  Confermo di aver compreso che l'iscrizione dovrà essere confermata dagli organizzatori.
                </span>
              </label>

              <label class="inline-option">
                <input
                  type="checkbox"
                  name="terms_privacy"
                  value="yes"
                  <%= formData?.terms_privacy === 'yes' ? 'checked' : '' %>
                  required
                />
                <span>
                  Autorizzo il trattamento dei dati personali nel rispetto del Regolamento Europeo 2016/679 e normativa vigente.
                </span>
              </label>

              <label class="inline-option">
                <input
                  type="checkbox"
                  name="terms_images"
                  value="yes"
                  <%= formData?.terms_images === 'yes' ? 'checked' : '' %>
                  required
                />
                <span>
                  Autorizzo la pubblicazione e/o diffusione gratuita delle immagini sui canali social del Palio della Torre e associazioni collegate.
                </span>
              </label>

              <label class="inline-option">
                <input
                  type="checkbox"
                  name="terms_liability"
                  value="yes"
                  <%= formData?.terms_liability === 'yes' ? 'checked' : '' %>
                  required
                />
                <span>
                  I partecipanti si assumono ogni responsabilità per l'attività sportiva e sollevano gli organizzatori da responsabilità civili e penali.
                </span>
              </label>
            </div>
          </div>

          <button type="submit" class="submit-btn">Invia iscrizione</button>
        </form>
      </div>
    </div>
  </div>

  <script>
    const sportSelect = document.getElementById('sport_id');
    const quotaText = document.getElementById('quotaText');
    const secondPlayerSection = document.getElementById('secondPlayerSection');

    const pairFields = [
      document.getElementById('player2_full_name'),
      document.getElementById('player2_tax_code'),
      document.getElementById('player2_phone'),
      document.getElementById('player2_rione_criteria'),
      document.getElementById('player2_rione_address')
    ];

    function updateSportUI() {
      const selected = sportSelect.options[sportSelect.selectedIndex];
      const price = selected?.dataset?.price || '';
      const type = selected?.dataset?.type || '';

      if (!price) {
        quotaText.textContent = '--';
        secondPlayerSection.style.display = 'none';
        pairFields.forEach(field => field.removeAttribute('required'));
        return;
      }

      if (type === 'pair') {
        quotaText.textContent = price + ' € a coppia';
        secondPlayerSection.style.display = 'block';
        pairFields.forEach(field => field.setAttribute('required', 'required'));
      } else {
        quotaText.textContent = price + ' €';
        secondPlayerSection.style.display = 'none';
        pairFields.forEach(field => field.removeAttribute('required'));
      }
    }

    sportSelect.addEventListener('change', updateSportUI);
    updateSportUI();
  </script>
</body>
</html>
