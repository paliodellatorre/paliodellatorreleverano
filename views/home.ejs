<%- include('partials/header') %>

<section class="hero">
  <div class="container hero-grid">
    <div>
      <div style="display:inline-block;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.12);padding:10px 14px;border-radius:999px;margin-bottom:18px;">Torneo dei Rioni • Iscrizioni 2026</div>
      <h1>Il Palio della Torre</h1>
      <p>
        Un evento che unisce sport, appartenenza e tradizione. Il Palio della Torre rappresenta la sfida tra rioni,
        la passione della comunità e lo spirito di squadra che ogni anno anima Leverano.
      </p>
      <div class="top-actions">
        <a href="#iscrizioni" class="button button-yellow">Iscrizioni 2026</a>
        <a href="#regolamenti" class="button button-outline">Scopri il regolamento</a>
      </div>
    </div>
    <div class="card hero-card">
      <div class="logo-circle">LOGO<br />PALIO</div>
      <div class="stats">
        <div class="stat"><strong><%= sports.length %></strong>Sport aperti</div>
        <div class="stat"><strong><%= settings.registrations_open === 'true' ? 'ON' : 'OFF' %></strong>Iscrizioni</div>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-title">
      <small>Storia del torneo</small>
      <h2>Storia del torneo dei rioni</h2>
      <p>Questa sezione può essere sostituita con la storia ufficiale del Palio della Torre, del torneo dei rioni e della sua evoluzione nel tempo.</p>
    </div>
    <div class="grid-3">
      <div class="card">Nato per valorizzare il senso di appartenenza ai rioni e creare un momento di festa condivisa.</div>
      <div class="card">Negli anni il Palio è diventato un appuntamento fisso, coinvolgendo atleti, famiglie, sponsor e volontari.</div>
      <div class="card">Oggi è una manifestazione simbolo di aggregazione, competizione sana e orgoglio locale.</div>
    </div>
  </div>
</section>

<section class="section" id="iscrizioni">
  <div class="container">
    <div class="section-title">
      <small>Iscrizioni online</small>
      <h2>Iscriviti agli sport del Palio</h2>
      <p>Le iscrizioni vengono salvate in un database PostgreSQL, quindi non si perdono nel pannello admin anche se il sito si riavvia.</p>
    </div>
    <div class="two-col">
      <div class="card">
        <% if (errors && errors.length) { %>
          <div class="notice notice-error">
            <% errors.forEach(function(error) { %>
              <div><%= error %></div>
            <% }) %>
          </div>
        <% } %>

        <% if (settings.registrations_open !== 'true') { %>
          <div class="notice notice-error">Le iscrizioni sono momentaneamente chiuse.</div>
        <% } %>

        <form method="post" action="/iscrizioni">
          <div class="form-grid">
            <div>
              <label>Nome e cognome</label>
              <input name="full_name" value="<%= formData.full_name || '' %>" required />
            </div>
            <div>
              <label>Data di nascita</label>
              <input type="date" name="birth_date" value="<%= formData.birth_date || '' %>" />
            </div>
            <div>
              <label>Telefono</label>
              <input name="phone" value="<%= formData.phone || '' %>" required />
            </div>
            <div>
              <label>Email</label>
              <input type="email" name="email" value="<%= formData.email || '' %>" required />
            </div>
            <div>
              <label>Rione</label>
              <input name="rione" value="<%= formData.rione || '' %>" required />
            </div>
            <div>
              <label>Sport</label>
              <select name="sport_id" required>
                <option value="">Seleziona uno sport</option>
                <% sports.forEach(function(sport) { %>
                  <option value="<%= sport.id %>" <%= String(formData.sport_id || '') === String(sport.id) ? 'selected' : '' %>><%= sport.name %> — €<%= Number(sport.price).toFixed(2) %></option>
                <% }) %>
              </select>
            </div>
          </div>
          <div style="margin-top:16px;">
            <label>Note</label>
            <textarea name="notes"><%= formData.notes || '' %></textarea>
          </div>
          <div style="margin-top:18px;">
            <button class="button button-yellow" type="submit" <%= settings.registrations_open !== 'true' ? 'disabled' : '' %>>Invia iscrizione</button>
          </div>
        </form>
      </div>
      <div class="card">
        <h3 style="margin-top:0;color:var(--green);font-size:1.7rem;">Sistema completo</h3>
        <div class="small" style="line-height:1.9;font-size:1rem;color:#374151">
          <div>• Iscrizione online per ogni sport</div>
          <div>• Pannello admin con elenco completo</div>
          <div>• Modifica ed eliminazione iscrizioni</div>
          <div>• Export Excel reale</div>
          <div>• Gestione prezzi</div>
          <div>• Chiusura generale iscrizioni</div>
          <div>• Chiusura singolo sport</div>
          <div>• Database PostgreSQL persistente</div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section" id="regolamenti">
  <div class="container">
    <div class="section-title">
      <small>Regolamenti</small>
      <h2>Regolamenti</h2>
      <p>Sezione pronta per inserire i regolamenti ufficiali del Palio della Torre.</p>
    </div>
    <div class="grid-4">
      <div class="card">Regolamento generale evento</div>
      <div class="card">Regolamento iscrizioni e quote</div>
      <div class="card">Regolamento sport e categorie</div>
      <div class="card">Privacy e trattamento dati</div>
    </div>
  </div>
</section>

<section class="section" id="chi-siamo">
  <div class="container">
    <div class="section-title">
      <small>Organizzazione</small>
      <h2>Chi siamo</h2>
      <p>Una sezione per raccontare il comitato organizzatore, la missione del Palio e i suoi valori.</p>
    </div>
    <div class="card">Il Palio della Torre nasce dalla volontà di promuovere lo sport, il territorio e il senso di comunità. Qui puoi aggiungere testo, foto e nomi dell'organizzazione.</div>
  </div>
</section>

<section class="section" id="contatti">
  <div class="container">
    <div class="section-title">
      <small>Contatti</small>
      <h2>Contatti</h2>
      <p>Riferimenti aggiornabili direttamente dal pannello admin.</p>
    </div>
    <div class="grid-3">
      <div class="card"><strong>Telefono</strong><br /><span class="small"><%= settings.contact_phone %></span></div>
      <div class="card"><strong>Email</strong><br /><span class="small"><%= settings.contact_email %></span></div>
      <div class="card"><strong>Sede</strong><br /><span class="small"><%= settings.contact_address %></span></div>
    </div>
  </div>
</section>

<section class="section" id="sponsor">
  <div class="container">
    <div class="section-title">
      <small>Partner</small>
    <div class="grid-4">

  <% sponsors.forEach(sponsor => { %>

    <div style="text-align:center; padding:20px;">

      <% if (sponsor.link) { %>
        <a href="<%= sponsor.link %>" target="_blank">
      <% } %>

      <img
        src="<%= sponsor.logo_url %>"
        style="
          max-width:160px;
          max-height:90px;
          object-fit:contain;
        "
      >

      <% if (sponsor.link) { %>
        </a>
      <% } %>

    </div>

  <% }) %>

</div>

<%- include('partials/footer') %>
