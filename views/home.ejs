<%- include('partials/header') %>

<section class="hero">
  <div class="container hero-grid">
    <div>
      <h1>Il Palio della Torre</h1>
      <p class="small" style="color:#FCBD16;font-weight:800;letter-spacing:.4px;">Torneo dei Rioni · Iscrizioni 2026</p>
      <p>Un evento che unisce sport, appartenenza e tradizione. Il Palio della Torre rappresenta la sfida tra rioni, la passione della comunità e lo spirito di squadra.</p>
      <div class="top-actions" style="margin-top:22px;"><a href="#iscrizioni" class="button button-yellow">Vai alle iscrizioni</a><a href="#regolamenti" class="button button-outline">Scopri i regolamenti</a></div>
    </div>
    <div class="card hero-card">
      <div class="logo-circle" style="padding:0; overflow:hidden; background:transparent;"><img src="/logo-pdt.png" alt="Logo Palio" style="width:100%; height:100%; object-fit:cover; border-radius:999px;"></div>
      <div class="stats"><div class="stat"><strong><%= sports.length %></strong><span>Sport aperti</span></div><div class="stat"><strong><%= settings.registrations_open === 'true' ? 'ON' : 'OFF' %></strong><span>Iscrizioni</span></div></div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-title"><small>Storia del torneo</small><h2>Storia del torneo dei rioni</h2><p style="font-weight:900;font-size:22px;color:var(--green);letter-spacing:1px;">#DIVIDEREPERUNIRE</p></div>
    <div class="grid-3"><div class="card">Nato per valorizzare il senso di appartenenza ai rioni e creare un momento di festa condivisa.</div><div class="card">Negli anni il Palio è diventato un appuntamento fisso, coinvolgendo atleti, famiglie, sponsor e volontari.</div><div class="card">Oggi è una manifestazione simbolo di aggregazione, competizione sana e orgoglio locale.</div></div>
  </div>
</section>

<section class="section" style="padding-top:0"><div class="container"><div class="card"><h3 style="margin-top:0;color:var(--green)">Come funziona</h3><p style="line-height:1.9;margin-bottom:0"><strong>1.</strong> Scegli il tuo sport.<br><strong>2.</strong> Inserisci i tuoi dati.<br><strong>3.</strong> Richiedi la maglietta del tuo rione.<br><strong>4.</strong> E il gioco è fatto.</p></div></div></section>

<section id="iscrizioni" class="section">
  <div class="container two-col"><div class="card"><h2>Iscrizioni sport</h2><p style="margin-top:0">Compila il modulo dal tuo smartphone. Per gli sport di coppia devi inserire anche il compagno dello stesso rione.</p>
    <% if (errors && errors.length) { %><div class="notice notice-error"><% errors.forEach(function(error) { %><div><%= error %></div><% }) %></div><% } %>
    <form method="POST" action="/iscrizioni" id="palioForm">
      <div class="form-grid">
        <div><label>Sport *</label><select name="sport_id" id="sport_id" required><option value="">Seleziona uno sport</option><% sports.forEach(function(sport){ const lowerName=String(sport.name||'').toLowerCase(); const isPair=lowerName.includes('coppia')||['padel','burraco','scopa','biliardino'].some(k=>lowerName.includes(k)); %><option value="<%= sport.id %>" data-price="<%= Number(sport.price).toFixed(2) %>" data-pair="<%= isPair ? 'true' : 'false' %>" <%= String(formData.sport_id||'')===String(sport.id)?'selected':'' %>><%= sport.name %> — €<%= Number(sport.price).toFixed(2) %><%= isPair ? ' a coppia' : '' %></option><% }) %></select></div>
        <div><label>Email *</label><input type="email" name="email" value="<%= formData.email || '' %>" required><div class="small" style="margin-top:8px">La email verrà registrata insieme all'iscrizione.</div></div>
        <div><label>Rione *</label><select name="rione" required><option value="">Scegli il tuo rione</option><% rioni.forEach(function(rione){ %><option value="<%= rione %>" <%= formData.rione===rione?'selected':'' %>><%= rione %></option><% }) %></select><div class="small" style="margin-top:8px">Consulta la mappa dei rioni <a href="https://www.google.com/maps/@40.2878732,17.9905045,15z/data=!3m1!4b1!4m2!6m1!1s1AiNo30X3Qloy24nwtxUo06kHozB_yC4" target="_blank" rel="noopener noreferrer" style="text-decoration:underline;font-weight:800">qui</a></div></div>
        <div><label>Conferma quota *</label><div class="card" style="padding:16px;border-radius:18px;box-shadow:none;border:1px solid #e5e7eb"><div style="line-height:1.7">Confermo di aver compreso che l'iscrizione ha un costo di <strong id="quotaLabel">seleziona uno sport</strong> da consegnare agli organizzatori prima dell'inizio del torneo. La maglia del proprio rione può essere acquistata a parte a € 5.</div><div class="radio-row" style="margin-top:12px"><label class="radio-inline"><input type="radio" name="fee_confirmation" value="yes" required><span>Sì</span></label><label class="radio-inline"><input type="radio" name="fee_confirmation" value="no"><span>No</span></label></div></div></div>
      </div>

      <div class="card" style="margin-top:20px"><h3 style="margin-top:0;color:var(--green)">1° giocatore</h3><div class="form-grid"><div><label>Nome e Cognome 1° giocatore *</label><input name="player1_full_name" value="<%= formData.player1_full_name || '' %>" required></div><div><label>Data di nascita 1° giocatore *</label><input type="date" name="player1_birth_date" value="<%= formData.player1_birth_date || '' %>" required></div><div><label>Codice fiscale 1° giocatore *</label><input name="player1_tax_code" value="<%= formData.player1_tax_code || '' %>" required></div><div><label>Numero di telefono 1° giocatore *</label><input name="player1_phone" value="<%= formData.player1_phone || '' %>" required></div><div><label>Criterio di appartenenza al Rione *</label><select name="player1_rione_criteria" required><option value="">Seleziona</option><% rioneCriteria.forEach(function(c){ %><option value="<%= c %>" <%= formData.player1_rione_criteria===c?'selected':'' %>><%= c %></option><% }) %></select></div></div><div style="margin-top:16px"><label>Indirizzo di appartenenza al Rione 1° giocatore *</label><input name="player1_rione_address" value="<%= formData.player1_rione_address || '' %>" required></div><div class="radio-row" style="margin-top:16px"><span style="font-weight:800;color:var(--green)">Vuoi acquistare la maglia del rione per il 1° giocatore? (+ € 5)</span><label class="radio-inline"><input type="radio" name="player1_shirt" value="yes" required><span>Sì</span></label><label class="radio-inline"><input type="radio" name="player1_shirt" value="no"><span>No</span></label></div><div id="player1_size_wrap" style="margin-top:16px;display:none"><label>Taglia maglia 1° giocatore *</label><select name="player1_shirt_size" id="player1_shirt_size"><option value="">Seleziona taglia</option><option>XS</option><option>S</option><option>M</option><option>L</option><option>XL</option><option>XXL</option></select></div></div>

      <div class="card" id="secondPlayerCard" style="margin-top:20px;display:none"><h3 style="margin-top:0;color:var(--green)">2° giocatore</h3><div class="form-grid"><div><label>Nome e Cognome 2° giocatore *</label><input name="player2_full_name" id="player2_full_name"></div><div><label>Data di nascita 2° giocatore *</label><input type="date" name="player2_birth_date" id="player2_birth_date"></div><div><label>Codice fiscale 2° giocatore *</label><input name="player2_tax_code" id="player2_tax_code"></div><div><label>Numero di telefono 2° giocatore *</label><input name="player2_phone" id="player2_phone"></div><div><label>Criterio di appartenenza al Rione *</label><select name="player2_rione_criteria" id="player2_rione_criteria"><option value="">Seleziona</option><% rioneCriteria.forEach(function(c){ %><option value="<%= c %>"><%= c %></option><% }) %></select></div></div><div style="margin-top:16px"><label>Indirizzo di appartenenza al Rione 2° giocatore *</label><input name="player2_rione_address" id="player2_rione_address"></div><div class="radio-row" style="margin-top:16px"><span style="font-weight:800;color:var(--green)">Vuoi acquistare la maglia del rione per il 2° giocatore? (+ € 5)</span><label class="radio-inline"><input type="radio" name="player2_shirt" value="yes"><span>Sì</span></label><label class="radio-inline"><input type="radio" name="player2_shirt" value="no"><span>No</span></label></div><div id="player2_size_wrap" style="margin-top:16px;display:none"><label>Taglia maglia 2° giocatore *</label><select name="player2_shirt_size" id="player2_shirt_size"><option value="">Seleziona taglia</option><option>XS</option><option>S</option><option>M</option><option>L</option><option>XL</option><option>XXL</option></select></div></div>

      <div class="card" style="margin-top:20px"><h3 style="margin-top:0;color:var(--green)">Conferme obbligatorie</h3><label class="checkbox"><input type="checkbox" name="terms_rione_check" value="yes" required>Confermo di aver compreso che l'appartenenza al Rione verrà verificata pena l'esclusione da tutte le attività del Torneo dei Rioni.</label><label class="checkbox"><input type="checkbox" name="terms_organizer_confirmation" value="yes" required>Confermo di aver compreso che l'iscrizione dovrà essere confermata dagli organizzatori.</label><label class="checkbox"><input type="checkbox" name="terms_privacy" value="yes" required>Autorizzo il trattamento dei dati personali nel rispetto del Regolamento Europeo 2016/679 e normativa vigente.</label><label class="checkbox"><input type="checkbox" name="terms_images" value="yes" required>Autorizzo la pubblicazione e/o diffusione gratuita delle immagini sui canali social del Palio della Torre e associazioni collegate.</label><label class="checkbox"><input type="checkbox" name="terms_liability" value="yes" required>I partecipanti si assumono ogni responsabilità per l'attività sportiva e sollevano gli organizzatori da responsabilità civili e penali.</label></div>
      <div style="margin-top:16px"><label>Note</label><textarea name="notes"><%= formData.notes || '' %></textarea></div><div style="margin-top:18px"><button class="button button-yellow" type="submit">Invia iscrizione</button></div>
    </form>
  </div></div>
</section>

<section id="regolamenti" class="section"><div class="container"><div class="section-title"><small>Regolamenti</small><h2>Regolamenti</h2></div><div class="grid-4"><% if (regulations && regulations.length) { %><% regulations.forEach(function(reg){ %><a href="<%= reg.file_url %>" target="_blank" class="card"><strong><%= reg.titolo %></strong></a><% }) %><% } else { %><div class="card">Regolamento generale</div><div class="card">Regolamento Padel</div><div class="card">Regolamento Calcio</div><div class="card">Privacy e trattamento dati</div><% } %></div></div></section>

<section id="novita" class="section"><div class="container"><div class="section-title"><small>Aggiornamenti</small><h2>NOVITÀ</h2></div><% if (news && news.length) { %><div style="display:grid;grid-template-columns:1fr;gap:20px"><% news.forEach(function(item){ %><div class="card" style="text-align:center;padding:24px"><% if (item.titolo) { %><div style="font-weight:800;color:var(--green);margin-bottom:14px"><%= item.titolo %></div><% } %><img src="<%= item.image_url %>" alt="Locandina novità" style="width:100%;max-height:none;object-fit:contain;display:block"></div><% }) %></div><% } else { %><div class="card">Nessuna novità disponibile al momento.</div><% } %></div></section>

<section id="chi-siamo" class="section"><div class="container"><div class="section-title"><small>Organizzazione</small><h2>Chi siamo</h2></div><div class="card">Il Palio della Torre di Leverano è una manifestazione sportiva e comunitaria che coinvolge i rioni del paese in sfide sportive e momenti di aggregazione, promuovendo lo spirito di squadra, il fair play e il senso di appartenenza al territorio.<br><br>Nato nel 2021, il Palio è cresciuto anno dopo anno diventando un appuntamento atteso da tutta la comunità, capace di unire giovani, famiglie e associazioni in un clima di festa e sana competizione.<br><br>La manifestazione rappresenta un'occasione unica per valorizzare lo sport, rafforzare i legami tra i cittadini e celebrare le tradizioni locali, trasformando ogni edizione in un momento di condivisione e partecipazione collettiva.<br><br>Il Palio della Torre si svolge con il patrocinio del Comune di Leverano, a testimonianza dell'importanza dell'evento per la comunità e per la promozione dei valori sportivi e sociali.</div></div></section>

<section id="contatti" class="section"><div class="container"><div class="section-title"><small>Contatti</small><h2>Contatti</h2><p>Seguici sui canali ufficiali del Palio della Torre.</p></div><div class="grid-3"><div class="card"><strong>Facebook</strong><div style="margin-top:10px"><a href="https://www.facebook.com/share/16jGEvJ7pg/?mibextid=wwXIfr" target="_blank" rel="noopener noreferrer" style="font-weight:700;text-decoration:none;color:inherit">Il Palio della Torre - Torneo dei Rioni Leverano</a></div></div><div class="card"><strong>Instagram</strong><div style="margin-top:10px"><a href="https://www.instagram.com/ilpaliodellatorreleverano?igsh=MTRrNjlrbDhwbDc3MA==" target="_blank" rel="noopener noreferrer" style="font-weight:700;text-decoration:none;color:inherit">ilpaliodellatorreleverano</a></div></div><div class="card"><strong>Email</strong><div style="margin-top:10px"><%= settings.contact_email || '---' %></div></div></div></div></section>

<section id="sponsor" class="section"><div class="container"><div class="section-title"><small>Partner</small><h2>Sponsor</h2></div><% if (sponsors && sponsors.length) { %><div style="display:grid;grid-template-columns:1fr;gap:20px"><% sponsors.forEach(function(sponsor){ %><div class="card" style="text-align:center;padding:28px"><img src="<%= sponsor.logo_url %>" alt="Sponsor" style="max-width:100%;max-height:170px;object-fit:contain"></div><% }) %></div><% } else { %><div style="display:grid;grid-template-columns:1fr;gap:20px"><div class="card">Sponsor 1</div><div class="card">Sponsor 2</div><div class="card">Sponsor 3</div><div class="card">Sponsor 4</div></div><% } %></div></section>

<script>
(function(){
  const sportSelect=document.getElementById('sport_id'), quotaLabel=document.getElementById('quotaLabel'), secondPlayerCard=document.getElementById('secondPlayerCard');
  const secondPlayerFields=['player2_full_name','player2_birth_date','player2_tax_code','player2_phone','player2_rione_criteria','player2_rione_address'].map(id=>document.getElementById(id));
  const p1Yes=document.querySelector('input[name="player1_shirt"][value="yes"]'), p1No=document.querySelector('input[name="player1_shirt"][value="no"]'), p1Wrap=document.getElementById('player1_size_wrap'), p1Size=document.getElementById('player1_shirt_size');
  const p2Yes=document.querySelector('input[name="player2_shirt"][value="yes"]'), p2No=document.querySelector('input[name="player2_shirt"][value="no"]'), p2Wrap=document.getElementById('player2_size_wrap'), p2Size=document.getElementById('player2_shirt_size');
  function updateSportUI(){const opt=sportSelect.options[sportSelect.selectedIndex];if(!opt||!opt.value){quotaLabel.textContent='seleziona uno sport';secondPlayerCard.style.display='none';secondPlayerFields.forEach(el=>el&&el.removeAttribute('required'));return}const price=opt.getAttribute('data-price')||'0.00';const isPair=opt.getAttribute('data-pair')==='true';quotaLabel.textContent='€'+price+(isPair?' a coppia':'');secondPlayerCard.style.display=isPair?'block':'none';secondPlayerFields.forEach(el=>{if(!el)return;isPair?el.setAttribute('required','required'):el.removeAttribute('required')});if(!isPair){if(p2Wrap)p2Wrap.style.display='none';if(p2Size)p2Size.removeAttribute('required')}}
  function updateP1(){if(p1Yes&&p1Yes.checked){p1Wrap.style.display='block';p1Size.setAttribute('required','required')}else{p1Wrap.style.display='none';p1Size.removeAttribute('required');p1Size.value=''}}
  function updateP2(){if(p2Yes&&p2Yes.checked&&secondPlayerCard.style.display!=='none'){p2Wrap.style.display='block';p2Size.setAttribute('required','required')}else{p2Wrap.style.display='none';p2Size.removeAttribute('required');p2Size.value=''}}
  if(sportSelect){sportSelect.addEventListener('change',()=>{updateSportUI();updateP2()});updateSportUI()} if(p1Yes)p1Yes.addEventListener('change',updateP1); if(p1No)p1No.addEventListener('change',updateP1); if(p2Yes)p2Yes.addEventListener('change',updateP2); if(p2No)p2No.addEventListener('change',updateP2); updateP1();updateP2();
})();
</script>

<% if (media && media.homepage_video_url) { %>
<div id="videoPopup" style="position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.85);display:flex;align-items:center;justify-content:center;z-index:9999;padding:20px">
  <button onclick="chiudiVideo()" style="position:absolute;top:20px;right:20px;background:white;border:none;border-radius:50%;width:42px;height:42px;font-size:22px;cursor:pointer;font-weight:bold;z-index:10000">✕</button>
  <video id="videoAdv" autoplay muted playsinline style="max-width:90%;max-height:90%;border-radius:12px;background:#000"><source src="<%= media.homepage_video_url %>" type="video/mp4"></video>
</div>
<script>
  function chiudiVideo(){document.getElementById('videoPopup').style.display='none'}
  function apriVideo(){const p=document.getElementById('videoPopup');const v=document.getElementById('videoAdv');p.style.display='flex';if(v){try{v.currentTime=0;v.play()}catch(e){}}}
  setInterval(apriVideo,30000);
</script>
<% } %>

<%- include('partials/footer') %>
