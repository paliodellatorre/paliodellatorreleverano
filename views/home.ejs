<%- include('partials/header') %>

<!-- HERO -->
<section class="hero">
  <div class="container hero-grid">

    <div>
      <span class="badge">Torneo dei Rioni · Iscrizioni 2026</span>

      <h1>Il Palio della Torre</h1>

      <p>
        Un evento che unisce sport, appartenenza e tradizione.
        Il Palio della Torre rappresenta la sfida tra rioni,
        la passione della comunità e lo spirito di squadra.
      </p>

      <div style="margin-top:20px;">
        <a href="#iscrizioni" class="button button-yellow">
          Iscriviti 2026
        </a>

        <a href="#regolamenti" class="button button-outline">
          Scopri il regolamento
        </a>
      </div>
    </div>

    <div class="card hero-card">

      <div class="logo-circle">
        LOGO<br>PALIO
      </div>

      <div class="stats">

        <div class="stat">
          <strong><%= sports.length %></strong>
          Sport aperti
        </div>

        <div class="stat">
          <strong>
            <%= settings.registrations_open === 'true' ? 'ON' : 'OFF' %>
          </strong>
          Iscrizioni
        </div>

      </div>

    </div>

  </div>
</section>

<!-- STORIA -->
<section class="section">

  <div class="container">

    <div class="section-title">
      <small>Storia del torneo</small>
      <h2>Storia del torneo dei rioni</h2>
      <p>
        Questa sezione può essere scritta con la storia ufficiale del Palio della Torre,
        del torneo dei rioni e della sua evoluzione nel tempo.
      </p>
    </div>

    <div class="grid-3">

      <div class="card">
        Nato per valorizzare il senso di appartenenza ai rioni e creare un momento di festa condivisa.
      </div>

      <div class="card">
        Negli anni il Palio è diventato un appuntamento fisso, coinvolgendo atleti, famiglie, sponsor e volontari.
      </div>

      <div class="card">
        Oggi è una manifestazione simbolo di aggregazione, competizione sana e orgoglio locale.
      </div>

    </div>

  </div>

</section>

<!-- ISCRIZIONI -->
<section id="iscrizioni" class="section">

  <div class="container two-col">

    <div class="card">

      <h2>Iscriviti agli sport del Palio</h2>

      <% if (errors.length) { %>
        <div class="notice notice-error">
          <% errors.forEach(e => { %>
            <div><%= e %></div>
          <% }) %>
        </div>
      <% } %>

      <form method="POST" action="/iscrizioni">

        <div class="form-grid">

          <div>
            <label>Nome e cognome</label>
            <input name="full_name" value="<%= formData.full_name || '' %>" required>
          </div>

          <div>
            <label>Data di nascita</label>
            <input type="date" name="birth_date" value="<%= formData.birth_date || '' %>">
          </div>

          <div>
            <label>Telefono</label>
            <input name="phone" value="<%= formData.phone || '' %>" required>
          </div>

          <div>
            <label>Email</label>
            <input name="email" value="<%= formData.email || '' %>" required>
          </div>

          <div>
            <label>Rione</label>

            <select name="rione" required>

              <option value="">
                Scegli il tuo rione
              </option>

              <% rioni.forEach(rione => { %>

                <option
                  value="<%= rione %>"
                  <%= formData.rione === rione ? 'selected' : '' %>
                >
                  <%= rione %>
                </option>

              <% }) %>

            </select>

          </div>

          <div>
            <label>Sport</label>

            <select name="sport_id" required>

              <option value="">
                Seleziona uno sport
              </option>

              <% sports.forEach(sport => { %>

                <option value="<%= sport.id %>">

                  <%= sport.name %>
                  —
                  <%= sport.price %> €

                </option>

              <% }) %>

            </select>

          </div>

        </div>

        <div style="margin-top:15px;">

          <label>Note</label>

          <textarea name="notes">
            <%= formData.notes || '' %>
          </textarea>

        </div>

        <div style="margin-top:20px;">

          <button class="button button-yellow">
            Invia iscrizione
          </button>

        </div>

      </form>

    </div>

    <div class="card">

      <h3>Sistema completo</h3>

      <ul>

        <li>Iscrizione online per ogni sport</li>
        <li>Pannello admin con elenco completo</li>
        <li>Modifica ed eliminazione iscrizioni</li>
        <li>Export Excel reale</li>
        <li>Gestione prezzi</li>
        <li>Chiusura generale iscrizioni</li>
        <li>Database PostgreSQL persistente</li>

      </ul>

    </div>

  </div>

</section>

<!-- REGOLAMENTI -->
<section id="regolamenti" class="section">

  <div class="container">

    <div class="section-title">
      <small>Regolamenti</small>
      <h2>Regolamenti</h2>
    </div>

    <div class="grid-4">

      <div class="card">
        Regolamento generale evento
      </div>

      <div class="card">
        Regolamento iscrizioni e quote
      </div>

      <div class="card">
        Regolamento sport e categorie
      </div>

      <div class="card">
        Privacy e trattamento dati
      </div>

    </div>

  </div>

</section>

<!-- CHI SIAMO -->
<section id="chi-siamo" class="section">

  <div class="container">

    <div class="section-title">
      <small>Organizzazione</small>
      <h2>Chi siamo</h2>
    </div>

    <div class="card">

      Il Palio della Torre nasce dalla volontà di promuovere lo sport,
      il territorio e il senso di comunità.

      Qui puoi aggiungere il testo ufficiale dell'organizzazione.

    </div>

  </div>

</section>

<!-- CONTATTI -->
<section id="contatti" class="section">

  <div class="container">

    <div class="section-title">
      <small>Contatti</small>
      <h2>Contatti</h2>
    </div>

    <div class="grid-3">

      <div class="card">

        Telefono

        <br><br>

        <strong>
          <%= settings.contact_phone || '---' %>
        </strong>

      </div>

      <div class="card">

        Email

        <br><br>

        <strong>
          <%= settings.contact_email || '---' %>
        </strong>

      </div>

      <div class="card">

        Sede

        <br><br>

        <strong>
          <%= settings.contact_address || 'Leverano (LE)' %>
        </strong>

      </div>

    </div>

  </div>

</section>

<!-- SPONSOR -->
<section id="sponsor" class="section">

  <div class="container">

    <div class="section-title">
      <small>Partner</small>
      <h2>Sponsor</h2>
    </div>

    <div class="grid-4">

      <% if (sponsors.length === 0) { %>

        <div class="card">Sponsor 1</div>
        <div class="card">Sponsor 2</div>
        <div class="card">Sponsor 3</div>
        <div class="card">Sponsor 4</div>

      <% } else { %>

        <% sponsors.forEach(sponsor => { %>

          <div class="card" style="text-align:center; padding:20px;">

            <img
              src="<%= sponsor.logo_url %>"
              style="max-width:100%; max-height:80px;"
            >

          </div>

        <% }) %>

      <% } %>

    </div>

  </div>

</section>

<%- include('partials/footer') %>
