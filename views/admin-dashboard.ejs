
<!-- File admin-dashboard.ejs corretto: Corsa completamente nascosta da admin -->

<%- include('partials/header') %>

<section class="section">
  <div class="container">
    <div class="section-title">
      <small>Pannello amministrazione</small>
      <h2>Pannello Admin</h2>
      <p>Gestione completa del Palio.</p>
    </div>

    <!-- ISCRIZIONI SEMPRE SOPRA -->

    <div class="card" style="margin-bottom:22px">
      <h3 style="margin-top:0;color:var(--green)">Elenco iscrizioni</h3>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Nome</th>
              <th>Rione</th>
              <th>Sport</th>
              <th>Contatti</th>
              <th>Azioni</th>
            </tr>
          </thead>
          <tbody>
            <% registrations.forEach(function(item){ %>
              <% if (String(item.sport_name || '').toLowerCase() !== 'corsa') { %>
                <tr>
                  <td><strong><%= item.full_name %></strong></td>
                  <td><%= item.rione %></td>
                  <td><%= item.sport_name %></td>
                  <td><%= item.phone %></td>
                  <td>
                    <a class="button button-green" href="/admin/registrations/<%= item.id %>/edit">Modifica</a>
                  </td>
                </tr>
              <% } %>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- GESTIONE SPORT SENZA CORSA -->

    <details class="card">
      <summary style="cursor:pointer;font-weight:900;color:var(--green)">
        Gestione sport ▶
      </summary>

      <div style="margin-top:18px">
        <% sports.forEach(function(sport){ %>
          <% if (String(sport.name || '').toLowerCase() !== 'corsa') { %>

            <form method="post" action="/admin/sports/<%= sport.id %>/update" class="sport-row">
              <div style="margin-bottom:10px">
                <label>Nome</label>
                <input name="name" value="<%= sport.name %>" required>
              </div>

              <div style="margin-bottom:10px">
                <label>Prezzo</label>
                <input type="number" step="0.01" min="0" name="price"
                       value="<%= Number(sport.price).toFixed(2) %>" required>
              </div>

              <div style="margin-bottom:14px;display:flex;align-items:center;gap:10px">
                <input type="checkbox" name="is_open"
                       <%= sport.is_open ? 'checked' : '' %> style="width:auto">
                <span>Sport aperto</span>
              </div>

              <button class="button button-yellow" type="submit">
                Salva sport
              </button>
            </form>

          <% } %>
        <% }) %>
      </div>
    </details>

  </div>
</section>

<%- include('partials/footer') %>
