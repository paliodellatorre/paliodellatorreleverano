<%- include('partials/header') %>
<section class="section">
  <div class="container">
    <div class="section-title">
      <small>Pannello amministrazione</small>
      <h2>Pannello Admin</h2>
      <p>Qui puoi gestire iscrizioni, prezzi, apertura o chiusura sport, contatti e scaricare il file Excel.</p>
    </div>

    <div class="top-actions" style="margin-bottom:18px;">
      <a class="button button-yellow" href="/admin/export/excel">Esporta Excel</a>
      <form class="inline-form" method="post" action="/admin/logout">
        <button class="button button-green" type="submit">Logout</button>
      </form>
    </div>

    <div class="admin-layout">
      <div>
        <div class="card" style="margin-bottom:20px;">
          <h3 style="margin-top:0;color:var(--green);">Impostazioni generali</h3>
          <form method="post" action="/admin/settings/update">
            <div style="margin-bottom:12px;">
              <label>Iscrizioni aperte</label>
              <select name="registrations_open">
                <option value="true" <%= settings.registrations_open === 'true' ? 'selected' : '' %>>Aperte</option>
                <option value="false" <%= settings.registrations_open !== 'true' ? 'selected' : '' %>>Chiuse</option>
              </select>
            </div>
            <div style="margin-bottom:12px;">
              <label>Telefono</label>
              <input name="contact_phone" value="<%= settings.contact_phone || '' %>" />
            </div>
            <div style="margin-bottom:12px;">
              <label>Email</label>
              <input name="contact_email" value="<%= settings.contact_email || '' %>" />
            </div>
            <div style="margin-bottom:14px;">
              <label>Sede</label>
              <input name="contact_address" value="<%= settings.contact_address || '' %>" />
            </div>
            <button class="button button-yellow" type="submit">Salva impostazioni</button>
          </form>
        </div>

        <div class="card" style="margin-bottom:20px;">
          <h3 style="margin-top:0;color:var(--green);">Aggiungi sport</h3>
          <form method="post" action="/admin/sports/create">
            <div style="margin-bottom:12px;">
              <label>Nome sport</label>
              <input name="name" required />
            </div>
            <div style="margin-bottom:14px;">
              <label>Prezzo</label>
              <input type="number" step="0.01" min="0" name="price" value="0" />
            </div>
            <button class="button button-green" type="submit">Aggiungi</button>
          </form>
        </div>

        <div class="card">
          <h3 style="margin-top:0;color:var(--green);">Gestione sport</h3>
          <% sports.forEach(function(sport) { %>
            <form method="post" action="/admin/sports/<%= sport.id %>/update" class="sport-row">
              <div style="margin-bottom:10px;">
                <label>Nome</label>
                <input name="name" value="<%= sport.name %>" required />
              </div>
              <div style="margin-bottom:10px;">
                <label>Prezzo</label>
                <input type="number" step="0.01" min="0" name="price" value="<%= Number(sport.price).toFixed(2) %>" required />
              </div>
              <div style="margin-bottom:14px; display:flex; align-items:center; gap:10px;">
                <input type="checkbox" name="is_open" <%= sport.is_open ? 'checked' : '' %> style="width:auto;" />
                <span>Sport aperto</span>
              </div>
              <button class="button button-yellow" type="submit">Salva sport</button>
            </form>
          <% }) %>
        </div>
      </div>

      <div>
        <% if (editItem) { %>
          <div class="card" style="margin-bottom:20px;">
            <h3 style="margin-top:0;color:var(--green);">Modifica iscrizione #<%= editItem.id %></h3>
            <form method="post" action="/admin/registrations/<%= editItem.id %>/update">
              <div class="form-grid">
                <div>
                  <label>Nome e cognome</label>
                  <input name="full_name" value="<%= editItem.full_name %>" required />
                </div>
                <div>
                  <label>Data di nascita</label>
                  <input type="date" name="birth_date" value="<%= editItem.birth_date ? new Date(editItem.birth_date).toISOString().slice(0,10) : '' %>" />
                </div>
                <div>
                  <label>Telefono</label>
                  <input name="phone" value="<%= editItem.phone %>" required />
                </div>
                <div>
                  <label>Email</label>
                  <input type="email" name="email" value="<%= editItem.email %>" required />
                </div>
                <div>
                  <label>Rione</label>
                  <input name="rione" value="<%= editItem.rione %>" required />
                </div>
                <div>
                  <label>Sport</label>
                  <select name="sport_id" required>
                    <% sports.forEach(function(sport) { %>
                      <option value="<%= sport.id %>" <%= Number(editItem.sport_id) === Number(sport.id) ? 'selected' : '' %>><%= sport.name %></option>
                    <% }) %>
                  </select>
                </div>
              </div>
              <div style="margin-top:12px;">
                <label>Note</label>
                <textarea name="notes"><%= editItem.notes || '' %></textarea>
              </div>
              <div class="top-actions" style="margin-top:16px;">
                <button class="button button-yellow" type="submit">Salva modifica</button>
                <a class="button button-green" href="/admin">Annulla</a>
              </div>
            </form>
          </div>
        <% } %>

        <div class="card">
          <h3 style="margin-top:0;color:var(--green);">Elenco iscrizioni</h3>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Nome</th>
                  <th>Rione</th>
                  <th>Sport</th>
                  <th>Contatti</th>
                  <th>Azioni</th>
                </tr>
              </thead>
              <tbody>
                <% if (!registrations.length) { %>
                  <tr><td colspan="5">Nessuna iscrizione presente.</td></tr>
                <% } %>
                <% registrations.forEach(function(item) { %>
                  <tr>
                    <td>
                      <strong><%= item.full_name %></strong><br />
                      <span class="small">Creato il <%= new Date(item.created_at).toLocaleString('it-IT') %></span>
                      <% if (item.notes) { %><br /><span class="small"><%= item.notes %></span><% } %>
                    </td>
                    <td><%= item.rione %></td>
                    <td><%= item.sport_name %><br /><span class="small">€<%= Number(item.sport_price).toFixed(2) %></span></td>
                    <td><%= item.phone %><br /><span class="small"><%= item.email %></span></td>
                    <td>
                      <div class="actions">
                        <a class="button button-green" href="/admin/registrations/<%= item.id %>/edit" style="padding:10px 14px;">Modifica</a>
                        <form class="inline-form" method="post" action="/admin/registrations/<%= item.id %>/delete" onsubmit="return confirm('Eliminare questa iscrizione?')">
                          <button class="button" style="background:#fee2e2;color:#991b1b;padding:10px 14px;">Elimina</button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
<%- include('partials/footer') %>

<div class="card" style="margin-top:20px;">
  <h2>Sponsor</h2>

  <form method="post" action="/admin/sponsors/create">
    <div class="form-grid">
      <div>
        <label>Logo (URL immagine)</label>
        <input name="logo_url" required>
      </div>

      <div>
        <label>Link (opzionale)</label>
        <input name="link">
      </div>
    </div>

    <button class="button button-yellow" type="submit">
      Aggiungi sponsor
    </button>
  </form>

  <hr style="margin:20px 0;">

  <div class="grid-4">
    <% sponsors.forEach(sponsor => { %>
      <div class="card" style="text-align:center;">

        <img
          src="<%= sponsor.logo_url %>"
          style="max-width:140px; max-height:80px; object-fit:contain;"
        >

        <form
          method="post"
          action="/admin/sponsors/<%= sponsor.id %>/delete"
          style="margin-top:10px;"
        >
          <button class="button button-green">
            Elimina
          </button>
        </form>

      </div>
    <% }) %>
  </div>
</div>
