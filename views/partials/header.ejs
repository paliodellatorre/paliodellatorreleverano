<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title || 'Il Palio della Torre' %></title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <% if (currentPath !== '/admin/login') { %>
    <header class="header">
      <div class="container header-brand-center">
        <a class="brand brand-centered" href="/?ok=1">
          <div class="brand-badge"><img src="/logo-pdt.png" alt="Logo Palio della Torre" /></div>
          <div class="brand-text"><div class="brand-title">IL PALIO DELLA TORRE</div><div class="brand-subtitle">Leverano</div></div>
        </a>
      </div>
      <div class="menu-strip">
        <div class="container menu-burger-inner">
          <details class="burger-menu">
            <summary class="burger-summary" aria-label="Apri menu">
              <span class="burger-lines" aria-hidden="true"><span></span><span></span><span></span></span>
              <span class="burger-label">MENU</span>
            </summary>
            <nav class="burger-panel" aria-label="Menu principale">
              <a href="/?ok=1">HOME</a>
              <a href="/iscrizioni?ok=1">ISCRIZIONI</a>
              <a href="/regolamenti?ok=1">REGOLAMENTI</a>
              <a href="/novita?ok=1">NOVITÀ</a>
              <a href="/chi-siamo?ok=1">CHI SIAMO</a>
              <a href="/sponsor?ok=1">SPONSOR</a>
            </nav>
          </details>
          <a href="/admin" class="admin-icon" title="Area admin" aria-label="Area admin"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 12c2.76 0 5-2.24 5-5s-2.24-5-5-5-5 2.24-5 5 2.24 5 5 5Zm0 2c-4.42 0-8 2.24-8 5v1c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2v-1c0-2.76-3.58-5-8-5Z"/></svg></a>
        </div>
      </div>
    </header>
  <% } %>
  <div class="container" style="padding-top:12px;">
    <% if (flash) { %><div class="notice <%= flash.type === 'success' ? 'notice-success' : 'notice-error' %>"><%= flash.message %></div><% } %>
  </div>
