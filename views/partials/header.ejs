<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <% if (currentPath !== '/admin/login') { %>
    <header class="header">
      <div class="container nav">
        <a class="brand" href="/">
          <div class="brand-badge" style="padding:0; overflow:hidden; background:transparent;">
            <img
              src="/logo-pdt.png"
              alt="Logo Palio della Torre"
              style="width:100%; height:100%; object-fit:cover; border-radius:18px;"
            />
          </div>

          <div>
            <div class="brand-title">Il Palio della Torre</div>
            <div class="small" style="color:#cdd8d5">Leverano</div>
          </div>
        </a>

        <nav class="nav-links">
          <a href="/#iscrizioni">ISCRIZIONI</a>
          <a href="/#regolamenti">REGOLAMENTI</a>
          <a href="/#chi-siamo">NOVITÀ</a>
          <a href="/#chi-siamo">CHI SIAMO</a>
          <a href="/#contatti">CONTATTI</a>
          <a href="/#sponsor">SPONSOR</a>
        </nav>

        <a
          href="/admin"
          class="button button-yellow"
          style="padding:10px 14px; min-width:46px; justify-content:center;"
          aria-label="Admin"
          title="Admin"
        >
          <span style="font-size:20px; line-height:1;">👤</span>
        </a>
      </div>
    </header>
  <% } %>

  <div class="container" style="padding-top: 12px;">
    <% if (flash) { %>
      <div class="notice <%= flash.type === 'success' ? 'notice-success' : 'notice-error' %>">
        <%= flash.message %>
      </div>
    <% } %>
  </div>
