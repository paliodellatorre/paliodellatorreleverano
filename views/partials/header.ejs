<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title || 'Il Palio della Torre' %></title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <% if (currentPath !== '/admin/login') { %>
    <header class="header">
      <div class="container nav">
        <a class="brand" href="/?ok=1">
          <div class="brand-badge"><img src="/logo-pdt.png" alt="PDT" style="width:100%;height:100%;object-fit:cover"></div>
          <div><div class="brand-title">IL PALIO DELLA TORRE</div><div class="small" style="color:#cdd8d5">Leverano</div></div>
        </a>
        <nav class="nav-links">
          <a href="/?ok=1#iscrizioni">ISCRIZIONI</a>
          <a href="/?ok=1#regolamenti">REGOLAMENTI</a>
          <a href="/?ok=1#novita">NOVITÀ</a>
          <a href="/?ok=1#chi-siamo">CHI SIAMO</a>
          <a href="/?ok=1#contatti">CONTATTI</a>
          <a href="/?ok=1#sponsor">SPONSOR</a>
          <a href="/admin" class="button button-yellow" style="padding:8px 12px;color:var(--green)" title="Admin">👤</a>
        </nav>
      </div>
    </header>
  <% } %>
  <div class="container" style="padding-top:12px;">
    <% if (flash) { %><div class="notice <%= flash.type === 'success' ? 'notice-success' : 'notice-error' %>"><%= flash.message %></div><% } %>
  </div>
