
<% if (media && media.homepage_video_url) { %>

<div id="videoPopup" style="
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.85);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 9999;
">
  <button
    id="closeVideoBtn"
    onclick="chiudiVideo()"
    style="
      position: absolute;
      top: 20px;
      right: 20px;
      background: white;
      border: none;
      border-radius: 50%;
      width: 40px;
      height: 40px;
      font-size: 22px;
      cursor: pointer;
      font-weight: bold;
      display: none;
      z-index: 10000;
    "
  >
    ✕
  </button>

  <video
    id="videoAdv"
    muted
    playsinline
    style="
      max-width: 90%;
      max-height: 90%;
      border-radius: 12px;
      background:#000;
    "
  >
    <source src="<%= media.homepage_video_url %>" type="video/mp4">
  </video>
</div>

<script>
  (function () {
    const INTERVALLO_PUBBLICITA = 120000; // 2 minuti
    const STORAGE_KEY = "palio_last_video_time";

    const popup = document.getElementById("videoPopup");
    const video = document.getElementById("videoAdv");
    const btn = document.getElementById("closeVideoBtn");

    if (!popup || !video || !btn) return;

    window.chiudiVideo = function () {
      popup.style.display = "none";
      try {
        video.pause();
        video.currentTime = 0;
      } catch (e) {}
    };

    function registraVisualizzazione() {
      localStorage.setItem(STORAGE_KEY, String(Date.now()));
    }

    function sonoPassatiDueMinuti() {
      const last = Number(localStorage.getItem(STORAGE_KEY) || 0);
      return !last || Date.now() - last >= INTERVALLO_PUBBLICITA;
    }

    function apriVideo() {
      popup.style.display = "flex";
      btn.style.display = "none";
      registraVisualizzazione();

      try {
        video.currentTime = 0;
        const playPromise = video.play();
        if (playPromise && typeof playPromise.catch === "function") {
          playPromise.catch(function () {});
        }
      } catch (e) {}
    }

    video.addEventListener("ended", function () {
      setTimeout(function () {
        btn.style.display = "block";
      }, 1000);
    });

    // Parte solo se sono passati almeno 2 minuti dall'ultima pubblicità,
    // anche se l'utente cambia pagina.
    if (sonoPassatiDueMinuti()) {
      setTimeout(apriVideo, 500);
    }

    // Controllo continuo ogni 5 secondi: appena passano 2 minuti, riparte.
    setInterval(function () {
      if (popup.style.display !== "flex" && sonoPassatiDueMinuti()) {
        apriVideo();
      }
    }, 5000);
  })();
</script>

<% } %>
