
<% if (media && media.homepage_video_url) { %>

<div id="videoPopup" style="
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.85);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
">
  <button
    id="closeVideoBtn"
    onclick="chiudiVideo()"
    style="
      position: absolute;
      top: 20px;
      right: 20px;
      background: white;
      border: none;
      border-radius: 50%;
      width: 40px;
      height: 40px;
      font-size: 22px;
      cursor: pointer;
      font-weight: bold;
      display: none;
    "
  >
    ✕
  </button>

  <video
    id="videoAdv"
    autoplay
    muted
    playsinline
    style="
      max-width: 90%;
      max-height: 90%;
      border-radius: 12px;
    "
  >
    <source src="<%= media.homepage_video_url %>" type="video/mp4">
  </video>
</div>

<script>
  function chiudiVideo() {
    document.getElementById("videoPopup").style.display = "none";
  }

  function apriVideo() {
    const popup = document.getElementById("videoPopup");
    const video = document.getElementById("videoAdv");
    const btn = document.getElementById("closeVideoBtn");

    popup.style.display = "flex";
    btn.style.display = "none";

    if (video) {
      video.currentTime = 0;
      video.play();
    }
  }

  const video = document.getElementById("videoAdv");
  const btn = document.getElementById("closeVideoBtn");

  if (video) {
    video.addEventListener("ended", function () {
      setTimeout(function () {
        btn.style.display = "block";
      }, 1000);
    });
  }

  setInterval(function () {
    apriVideo();
  }, 120000);
</script>

<% } %>
