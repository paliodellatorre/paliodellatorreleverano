<% if (media && media.homepage_video_url) { %>

<div id="videoPopup" style="
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.85);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  padding: 20px;
">
  <button
    id="closeVideoBtn"
    onclick="chiudiVideo()"
    style="
      position: absolute;
      top: 20px;
      right: 20px;
      background: white;
      border: none;
      border-radius: 50%;
      width: 40px;
      height: 40px;
      font-size: 22px;
      cursor: pointer;
      font-weight: bold;
      display: none;
      z-index: 10000;
    "
  >
    ✕
  </button>

  <video
    id="videoAdv"
    muted
    playsinline
    style="
      width: min(900px, 100%);
      max-height: 85vh;
      border-radius: 18px;
      background: #000;
      display: block;
    "
  >
    <source src="<%= media.homepage_video_url %>" type="video/mp4">
  </video>
</div>

<script>
  (function () {
    const STORAGE_KEY = "palio_video_pubblicita_vista";
    const popup = document.getElementById("videoPopup");
    const video = document.getElementById("videoAdv");
    const btn = document.getElementById("closeVideoBtn");

    if (!popup || !video || !btn) return;

    window.chiudiVideo = function () {
      popup.style.display = "none";
      try {
        video.pause();
        video.currentTime = 0;
      } catch (e) {}
    };

    function mostraVideoSoloUnaVolta() {
      if (localStorage.getItem(STORAGE_KEY) === "yes") return;

      localStorage.setItem(STORAGE_KEY, "yes");

      popup.style.display = "flex";
      btn.style.display = "none";

      try {
        video.currentTime = 0;
        const playPromise = video.play();
        if (playPromise && typeof playPromise.catch === "function") {
          playPromise.catch(function () {
            // Se il browser blocca autoplay, mostro comunque la X per chiudere.
            setTimeout(function () {
              btn.style.display = "block";
            }, 1000);
          });
        }
      } catch (e) {}
    }

    video.addEventListener("ended", function () {
      setTimeout(function () {
        btn.style.display = "block";
      }, 1000);
    });

    // Compare solo una volta quando accedono al sito, poi basta.
    setTimeout(mostraVideoSoloUnaVolta, 500);
  })();
</script>

<% } %>
