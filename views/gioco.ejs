
<%- include('partials/header') %>

<link rel="stylesheet" href="/pdt-jump.css">

<section class="pdt-game-page">
  <div class="pdt-game-shell">

    <div class="pdt-game-layout">
      <div class="pdt-game-card">
        <div id="pdtStartPanel" class="pdt-panel">
          <h3>PDT JUMP 🐸</h3>

          <div id="pdtLockedPlayer" class="pdt-locked-player" style="display:none;"></div>

          <div id="pdtPlayerForm">
            <label>Nickname</label>
            <input id="pdtNickname" maxlength="24" autocomplete="off">

            <label>Rione</label>
            <select id="pdtRione">
              <option value="">Scegli il rione</option>
              <option value="Centro">Centro</option>
              <option value="Chianca">Chianca</option>
              <option value="Consolazione">Consolazione</option>
              <option value="Iana">Iana</option>
              <option value="Patula Cupa - Quartararu">Patula Cupa - Quartararu</option>
              <option value="Pozzolungo Nord">Pozzolungo Nord</option>
              <option value="Pozzolungo Sud">Pozzolungo Sud</option>
              <option value="Zita Rosa">Zita Rosa</option>
            </select>
          </div>

          <button id="pdtStartBtn" class="button button-yellow" type="button">INIZIA</button>
          <div id="pdtStartError" class="pdt-error"></div>
        </div>

        <div id="pdtEndPanel" class="pdt-panel" style="display:none;">
          <h3>Partita terminata</h3>
          <p id="pdtFinalText"></p>
          <div class="pdt-end-actions">
            <button id="pdtRestartBtn" class="button button-yellow" type="button">RIGIOCA</button>
            <button id="pdtShareBtn" class="button button-green" type="button">CONDIVIDI</button>
          </div>
        </div>
      </div>

      <div class="pdt-leaderboard-card">
        <h3>Classifica Top 10</h3>
        <ol id="pdtLeaderboard"></ol>
      </div>
    </div>
  </div>
</section>

<div id="pdtGameOverlay" class="pdt-game-overlay" style="display:none;">
  <div id="pdtCountdown" style="
      position:absolute;
      inset:0;
      display:flex;
      align-items:center;
      justify-content:center;
      font-size:80px;
      font-weight:900;
      color:white;
      z-index:10;
      pointer-events:none;
  "></div>

  <div id="pdtHint" style="
      position:absolute;
      left:10px;
      right:10px;
      bottom:20px;
      text-align:center;
      color:white;
      font-weight:900;
      display:none;
  ">
      Tocca sinistra o destra per muovere la rana
  </div>

  <canvas id="pdtCanvas" width="420" height="720"></canvas>
</div>

<script src="/pdt-jump.js"></script>

<%- include('partials/footer') %>
